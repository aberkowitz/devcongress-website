---
interface Social {
  platform: string;
  url: string;
}

interface Props {
  socials: Social[];
}

const { socials } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <nav>
    <ul>
      <li><a href="#mission">Mission</a></li>
      <li><a href="#activities">Activities</a></li>
      <li><a href="#meetups">Meetups</a></li>
      <li><a href="#team">Team</a></li>
      <li><a href="#partners">Partners</a></li>
      <li><a href="#donate">Support Us</a></li>
    </ul>
  </nav>
  <ul>
    {socials.map((s) => (
      <li>
        <a href={s.url} target="_blank" rel="noopener noreferrer">{s.platform}</a>
      </li>
    ))}
  </ul>
  <p>
    &copy; {year} DevCongress. Building Africa's tech community.
  </p>
  <p>
    <a href="mailto:hello@devcongress.org">hello@devcongress.org</a>
  </p>
</footer>

---
interface Social {
  platform: string;
  url: string;
}

interface Admin {
  id: string;
  data: {
    name: string;
    image: string;
    socials: Social[];
  };
}

interface Props {
  admins: Admin[];
}

const { admins } = Astro.props;
const sorted = [...admins].sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<section id="team">
  <h2>The Team</h2>
  <ul>
    {sorted.map((admin) => (
      <li>
        <article>
          <img src={admin.data.image} alt={admin.data.name} loading="lazy" />
          <h3>{admin.data.name}</h3>
          <ul>
            {admin.data.socials.map((social) => (
              <li>
                <a href={social.url} target="_blank" rel="noopener noreferrer">{social.platform}</a>
              </li>
            ))}
          </ul>
        </article>
      </li>
    ))}
  </ul>
</section>

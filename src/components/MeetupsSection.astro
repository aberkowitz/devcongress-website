---
interface MeetupLocation { name: string; map_url?: string | null; }
interface Meetup {
  id: string;
  data: {
    name: string;
    start: string;
    end: string;
    location: MeetupLocation;
    description: string;
    cover: string;
    photos?: string[];
    registration_url?: string | null;
    stream_url?: string | null;
  };
}
interface Props { meetups: Meetup[]; }
const { meetups } = Astro.props;

function getMeetupStatus(start: string, end: string) {
  const now  = new Date();
  const s    = new Date(start);
  const e    = new Date(end);
  return now < s ? 'upcoming' : now <= e ? 'live' : 'past';
}

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

const sorted = [...meetups]
  .sort((a, b) => new Date(b.data.start).getTime() - new Date(a.data.start).getTime())
  .map((m) => ({
    ...m,
    slug:   m.id,
    status: getMeetupStatus(m.data.start, m.data.end),
  }));

const statusConfig = {
  upcoming: { label: 'Upcoming', cta: 'Register →' },
  live:     { label: '● Live',   cta: 'Watch live →' },
  past:     { label: 'Past',     cta: 'View recap →' },
};
---

<section class="section" id="meetups">
  <div class="container">

    <div class="meetups-header">
      <span class="eyebrow">Meetups</span>
      <h2 class="heading-serif meetups-heading">Where we show up</h2>
    </div>

    <ul class="meetups-grid">
      {sorted.map((meetup) => {
        const cfg = statusConfig[meetup.status];
        const photoCount = meetup.data.photos?.length ?? 0;
        return (
          <li class="meetup-card card">
            <a href={`/website/meetups/${meetup.slug}/`} class="meetup-cover-link" aria-hidden="true" tabindex="-1">
              <div class="meetup-cover" style={`background-image: url('${meetup.data.cover}')`}>
                <span class={`meetup-status-badge status-${meetup.status}`}>{cfg.label}</span>
                {photoCount > 0 && (
                  <span class="meetup-photo-badge">{photoCount} photos</span>
                )}
              </div>
            </a>
            <div class="meetup-body">
              <div class="meetup-meta">
                <time datetime={meetup.data.start}>{formatDate(meetup.data.start)}</time>
                <span class="meetup-location">{meetup.data.location.name}</span>
              </div>
              <h3 class="heading-serif meetup-name">
                <a href={`/website/meetups/${meetup.slug}/`}>{meetup.data.name}</a>
              </h3>
              <p class="meetup-desc">{meetup.data.description}</p>
              <a href={`/website/meetups/${meetup.slug}/`} class="btn btn-outline meetup-cta">
                {cfg.cta}
              </a>
            </div>
          </li>
        );
      })}
    </ul>

  </div>
</section>

<style>
  .meetups-header {
    margin-bottom: var(--s8);
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }

  .meetups-heading { font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl)); }

  .meetups-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s5);
  }
  @media (min-width: 720px) { .meetups-grid { grid-template-columns: 1fr 1fr; } }

  .meetup-card { overflow: hidden; display: flex; flex-direction: column; }

  .meetup-cover-link { display: block; }

  .meetup-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--border-light);
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: var(--s3);
    transition: opacity 200ms ease;
  }
  .meetup-card:hover .meetup-cover { opacity: 0.9; }

  .meetup-status-badge {
    font-size: var(--text-xs);
    font-weight: 700;
    border: 2px solid var(--black);
    border-radius: var(--r-sm);
    padding: 2px var(--s2);
  }
  .status-upcoming { background: var(--yellow);    color: var(--black); }
  .status-live     { background: var(--pink);      color: #fff;         }
  .status-past     { background: var(--bg-white);  color: var(--text-muted); }

  .meetup-photo-badge {
    font-size: var(--text-xs);
    font-weight: 700;
    background: rgba(0,0,0,0.6);
    color: #fff;
    border-radius: var(--r-sm);
    padding: 2px var(--s2);
  }

  .meetup-body {
    padding: var(--s5);
    display: flex;
    flex-direction: column;
    gap: var(--s3);
    flex: 1;
    border-top: 2px solid var(--black);
  }

  .meetup-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-wrap: wrap;
    gap: var(--s2);
  }

  .meetup-location { color: var(--pink); }

  .meetup-name { font-size: var(--text-xl); line-height: var(--leading-snug); }
  .meetup-name a:hover { color: var(--pink); }

  .meetup-desc {
    font-size: var(--text-sm);
    color: var(--text-mid);
    line-height: var(--leading-body);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .meetup-cta { align-self: flex-start; margin-top: var(--s2); }
</style>

---
interface Meetup {
  id: string;
  data: {
    name: string;
    date: string;
    location: string;
    description: string;
    cover: string;
    photos: string[];
  };
}
interface Props { meetups: Meetup[]; }
const { meetups } = Astro.props;
const sorted = [...meetups]
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .map((m) => ({ ...m, slug: m.id.replace(/\/meta$/, '') }));

function formatDate(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<section class="section" id="meetups">
  <div class="container">
    <p class="section-label">Meetups</p>
    <h2 class="section-heading meetups-heading">Where we show up</h2>

    <ul class="meetups-grid">
      {sorted.map((meetup) => (
        <li class="meetup-card">
          <a href={`/website/meetups/${meetup.slug}/`} class="meetup-cover-link" aria-hidden="true" tabindex="-1">
            <div class="meetup-cover" style={`background-image: url('${meetup.data.cover}')`}></div>
          </a>
          <div class="meetup-body">
            <div class="meetup-meta">
              <time datetime={meetup.data.date}>{formatDate(meetup.data.date)}</time>
              <span class="meetup-sep" aria-hidden="true">&middot;</span>
              <span>{meetup.data.location}</span>
              <span class="meetup-count">{meetup.data.photos.length} photos</span>
            </div>
            <h3 class="meetup-name">
              <a href={`/website/meetups/${meetup.slug}/`}>{meetup.data.name}</a>
            </h3>
            <p class="meetup-desc">{meetup.data.description}</p>
            <a href={`/website/meetups/${meetup.slug}/`} class="meetup-link">
              View photos &rarr;
            </a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .meetups-heading { margin-bottom: var(--space-7); }

  .meetups-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 720px) {
    .meetups-grid { grid-template-columns: 1fr 1fr; }
  }

  .meetup-card {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease;
  }
  .meetup-card:hover { border-color: var(--color-text-faint); }

  .meetup-cover-link { display: block; }

  .meetup-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--color-bg-subtle);
  }

  .meetup-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meetup-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .meetup-sep { color: var(--color-text-faint); }

  .meetup-count {
    margin-left: auto;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 2px var(--space-3);
  }

  .meetup-name {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-snug);
  }
  .meetup-name a:hover { color: var(--color-accent); }

  .meetup-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meetup-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
    transition: opacity 150ms ease;
  }
  .meetup-link:hover { opacity: 0.8; }
</style>

---
interface Props { paystackUrl: string; }
const { paystackUrl } = Astro.props;
---

<section class="section donate-section" id="donate">
  <div class="container">
    <div class="donate-card">
      <p class="section-label">Support</p>
      <h2 class="donate-heading">Keep DevCongress running</h2>
      <p class="donate-sub">
        DevCongress is community-funded. Every contribution directly supports the people and programs that make this community work.
      </p>
      <ul class="donate-uses">
        <li>
          <span class="donate-dot" aria-hidden="true"></span>
          Monthly meetups across Africa
        </li>
        <li>
          <span class="donate-dot" aria-hidden="true"></span>
          The Chale Code mentorship program
        </li>
        <li>
          <span class="donate-dot" aria-hidden="true"></span>
          Community tools and shared resources
        </li>
      </ul>
      <a href={paystackUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary donate-btn">
        Donate via Paystack
      </a>
    </div>
  </div>
</section>

<style>
  .donate-section { background: var(--color-bg-raised); }

  .donate-card {
    max-width: 600px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .donate-heading {
    font-family: var(--font-display);
    font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .donate-sub {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    max-width: 480px;
  }

  .donate-uses {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-align: left;
    width: 100%;
    max-width: 400px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .donate-uses li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .donate-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .donate-btn { margin-top: var(--space-2); }
</style>

---
interface Props {
  slackUrl: string;
}

const { slackUrl } = Astro.props;
---

<section id="get-started">
  <h2>Your path to growth and impact starts here.</h2>
  <ol>
    <li>
      <h3>Community &amp; Network</h3>
      <p>
        Join a vibrant ecosystem of developers, designers, and tech entrepreneurs.
        Attend meetups, workshops, and hackathons. Build relationships that open doors.
      </p>
    </li>
    <li>
      <h3>Access Resources &amp; Opportunities</h3>
      <p>
        Get access to learning resources, job postings, freelance gigs, and mentorship
        programs. Stay ahead with the latest in tech.
      </p>
    </li>
    <li>
      <h3>Collaborate &amp; Contribute</h3>
      <p>
        Work on open-source projects, contribute to community initiatives, and build
        your portfolio with real-world experience.
      </p>
    </li>
  </ol>
  <a href={slackUrl} target="_blank" rel="noopener noreferrer">Join Community</a>
</section>

---
interface MissionItem {
  heading: string;
  description: string;
  stat: string;
}
interface Props { mission: MissionItem[]; slackUrl: string; }
const { mission, slackUrl } = Astro.props;
const nums = ['01', '02', '03', '04'];
---

<section class="section" id="community">
  <div class="container mission-grid">
    <div class="mission-statement">
      <p class="section-label">Mission</p>
      <h2 class="mission-headline">
        We exist because Africa's builders deserve a community that takes them seriously.
      </h2>
      <a href={slackUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Join on Slack
      </a>
    </div>

    <ol class="mission-list">
      {mission.map((item, i) => (
        <li class="mission-item">
          <span class="mission-num">{nums[i]}</span>
          <div class="mission-body">
            <h3 class="mission-item-heading">{item.heading}</h3>
            <p class="mission-item-desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-9);
  }

  @media (min-width: 900px) {
    .mission-grid {
      grid-template-columns: 5fr 7fr;
      gap: var(--space-8);
      align-items: start;
    }
  }

  .mission-statement {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
    position: sticky;
    top: 88px;
  }

  .mission-headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
    font-weight: 700;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  .mission-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mission-item {
    display: flex;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }
  .mission-item:first-child { border-top: 1px solid var(--color-border); }

  .mission-num {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    flex-shrink: 0;
    width: 2ch;
    padding-top: 2px;
  }

  .mission-body { display: flex; flex-direction: column; gap: var(--space-2); }

  .mission-item-heading {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    line-height: var(--leading-snug);
  }

  .mission-item-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
  }
</style>
